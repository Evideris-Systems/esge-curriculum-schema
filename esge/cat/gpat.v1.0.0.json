  "catFamily": "GPAT",
  "title": { "en": "Global Polypectomy Assessment Tool (GPAT)" },
  "description": { "en": "Components of the Global Polypectomy Assessment Tool (GPAT)." },

  "applicableModalities": ["m-colonoscopy-emr"],
  "introducedIn": "cur-emr-colon-2023",

  "scoringScale": {
    "kind": "ordinal",
    "levels": [
      { "value": 1, "label": { "en": "Very poor" } },
      { "value": 5, "label": { "en": "Very good" } }
    ]
  },

  "items": [
    {
      "lineageId": "cat-gpat-snare-type",
      "label": { "en": "Snare type" },
      "guidance": { "en": "Use a dedicated cold snare; Recommendation 17(i)" },
      "assessesRecommendations": [
        { "lineageId": "rec-emr-cln-r17-cold-snare-placement", "subItem": "i" }
      ],
      "applicability": { "hot-snare": "mandatory", "cold-snare": "mandatory" }
    },
    {
      "lineageId": "cat-gpat-maximizing-tissue-capture",
      "label": { "en": "Maximizing tissue capture" },
      "guidance": { "en": "For cold snare using a dedicated thin-wire snare pushing the snare against the colonic wall is also effective to maximize tissue capture; Recommendation 17(viii)" },
      "assessesRecommendations": [
        { "lineageId": "rec-emr-cln-r17-cold-snare-placement", "subItem": "viii" }
      ],
      "applicability": { "hot-snare": "mandatory", "cold-snare": "mandatory" }
    },
    {
      "lineageId": "cat-gpat-defect-mucosa",
      "label": { "en": "Mucosa: looks for, detects, and removes residual adenomatous tissue at margin and within defect" },
      "guidance": { "en": "Ostensibly and systematically checks for residual adenomatous tissue within the defect and at the defect margin, and removes it successfully" },
      "applicability": { "hot-snare": "mandatory", "cold-snare": "mandatory" }
    },
    {
      "lineageId": "cat-gpat-defect-muscularis",
      "label": { "en": "Muscularis: looks for, detects, and treats deep mural injury ≥II (Sydney classification)" },
      "guidance": { "en": "Detects and treats types II–V deep mural injury or confirms they are not present" },
      "applicability": { "hot-snare": "mandatory", "cold-snare": "not-applicable" }
    }
  ],

