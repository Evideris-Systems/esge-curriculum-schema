{
  "$schema": "https://schema.evideris.com/schemas/scoring-tool.schema.json",
  "$id": "https://schema.evideris.com/esge/scoring-tool/smsa.v1.0.0.json",
  "lineageId": "st-smsa",
  "type": "scoringTool",
  "version": "1.0.0",
  "release": "r2026.07",
  "supersedes": null,
  "supersededBy": null,
  "language": ["en"],

  "title": { "en": "SMSA (size, morphology, site, and access) score" },
  "description": { "en": "The SMSA score is composed of four domains, which are allocated points; adding the points for each domain results in a score of 1–4." },
  "domain": "polypectomy-difficulty",

  "scale": {
    "kind": "composite-additive",
    "min": 4,
    "max": 12,
    "bands": [
      { "label": { "en": "1" },     "from": 4,  "to": 5  },
      { "label": { "en": "2" },     "from": 6,  "to": 9  },
      { "label": { "en": "3" },     "from": 9,  "to": 12 },
      { "label": { "en": "4" },     "from": 13, "to": 99 }
    ]
  },

  "inputs": [
    {
      "name": "size",
      "label": { "en": "Size, cm" },
      "values": [
        { "score": 1, "label": { "en": "< 1 cm" } },
        { "score": 3, "label": { "en": "1–1.9" } },
        { "score": 5, "label": { "en": "2–2.9" } },
        { "score": 7, "label": { "en": "3–3.9" } },
        { "score": 9, "label": { "en": "> 4" } }
      ]
    },
    {
      "name": "morphology",
      "label": { "en": "Morphology" },
      "values": [
        { "score": 1, "label": { "en": "Pedunculated" } },
        { "score": 2, "label": { "en": "Sessile" } },
        { "score": 3, "label": { "en": "Flat" } }
      ]
    },
    {
      "name": "site",
      "label": { "en": "Site" },
      "values": [
        { "score": 1, "label": { "en": "Left colon" } },
        { "score": 2, "label": { "en": "Right colon" } }
      ]
    },
    {
      "name": "access",
      "label": { "en": "Access" },
      "values": [
        { "score": 1, "label": { "en": "Easy" } },
        { "score": 3, "label": { "en": "Difficult" } }
      ]
    }
  ],

  "references": [
    {
      "id": "ref-36",
      "citation": "Gupta S, Miskovic D, Bhandari P et al. A novel method for determining the difficulty of colonoscopic polypectomy. Frontline Gastroenterol 2013; 4: 244–248. doi:10.1136/flgastro-2013-100331"
    }
  ],

  "_meta": {
    "provenance": {
      "type": "verbatim",
      "source_doi": "10.1055/a-2077-0497"
    },
    "encodedBy": "human:david",
    "encodedAt": "2026-06-27"
  }
}
