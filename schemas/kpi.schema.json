{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.evideris.com/schemas/kpi.schema.json",
  "title": "Key Performance Indicator (KPI) — training target",
  "description": "Training-target metric. Distinct from `qi`, which is a lifelong quality indicator for the established practitioner.",
  "type": "object",
  "allOf": [{ "$ref": "_common.schema.json#/$defs/envelope" }],
  "required": ["type", "withinCurriculum", "title", "metric", "unit", "appliesTo"],
  "properties": {
    "type":             { "const": "kpi" },
    "withinCurriculum": { "$ref": "_common.schema.json#/$defs/lineageId" },
    "title":            { "$ref": "_common.schema.json#/$defs/localeKeyedString" },
    "metric":           { "$ref": "_common.schema.json#/$defs/localeKeyedString" },
    "unit":             { "type": "string" },
    "desiredStandard":  { "type": ["number", "null"] },
    "minimumStandard":  { "type": ["number", "null"] },
    "originData": {
      "type": "object",
      "properties": {
        "source":               { "type": ["string", "null"], "description": "delphi | iACE | study citation tag" },
        "value":                { "type": ["number", "null"] },
        "confidenceInterval95": {
          "type": ["object", "null"],
          "properties": {
            "low":  { "type": "number" },
            "high": { "type": "number" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "levelOfAgreement": { "type": "integer", "minimum": 0, "maximum": 100 },
    "appliesTo":        { "enum": ["trainee", "trainer", "unit", "centre", "service", "practitioner"] },
    "derivedFromRecommendation": { "$ref": "_common.schema.json#/$defs/lineageId" },
    "$schema": true, "$id": true, "lineageId": true, "version": true, "release": true,
    "supersedes": true, "supersededBy": true, "language": true
  },
  "additionalProperties": false
}
