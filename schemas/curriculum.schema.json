{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schema.evideris.com/schemas/curriculum.schema.json",
  "title": "ESGE curriculum (publication wrapper)",
  "description": "Container for a Delphi-derived ESGE publication: authors, journal, methodology, sections, references, and arrays of lineageIds for every recommendation/competency/EPA/etc the publication introduces.",
  "type": "object",
  "allOf": [{ "$ref": "_common.schema.json#/$defs/envelope" }],
  "required": ["type", "scope", "targetModalities", "publication", "methodology", "mainStatements"],
  "properties": {
    "type":      { "const": "curriculum" },
    "scope":     { "$ref": "_common.schema.json#/$defs/localeKeyedString" },
    "targetModalities": {
      "type": "array",
      "items": { "$ref": "_common.schema.json#/$defs/lineageId" },
      "minItems": 1
    },
    "publication": {
      "type": "object",
      "required": ["title", "authors", "journal", "year", "doi"],
      "properties": {
        "title":   { "type": "string" },
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name":        { "type": "string" },
              "affiliation": { "type": "string" }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "journal": { "type": "string" },
        "year":    { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "volume":  { "type": ["integer", "string"] },
        "issue":   { "type": ["integer", "string"] },
        "pages":   { "type": "string" },
        "doi":     { "type": "string" },
        "openAccessUrl": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "methodology": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type":   { "enum": ["delphi-consensus", "narrative-review", "guideline"] },
        "rounds": { "type": "integer", "minimum": 1 },
        "agreementThreshold": { "type": "integer", "minimum": 0, "maximum": 100 },
        "panelSize": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "mainStatements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["number", "text"],
        "properties": {
          "number": { "type": "integer", "minimum": 1 },
          "text":   { "$ref": "_common.schema.json#/$defs/localeKeyedString" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lineageId", "number", "title"],
        "properties": {
          "lineageId": { "$ref": "_common.schema.json#/$defs/lineageId" },
          "number":    { "type": "integer", "minimum": 1 },
          "title":     { "$ref": "_common.schema.json#/$defs/localeKeyedString" }
        },
        "additionalProperties": false
      }
    },
    "recommendations": { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "competencies":    { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "epas":            { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "standards":       { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "scoringTools":    { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "kpis":            { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "qis":             { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "cats":            { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "prerequisites":   { "type": "array", "items": { "$ref": "_common.schema.json#/$defs/lineageId" } },
    "disclaimer":      { "type": "string" },
    "acknowledgments": { "type": "string" },
    "competingInterests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["author", "statement"],
        "properties": {
          "author":    { "type": "string" },
          "statement": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "citation"],
        "properties": {
          "id":       { "$ref": "_common.schema.json#/$defs/citationRef" },
          "citation": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "$schema": true, "$id": true, "lineageId": true, "version": true, "release": true,
    "supersedes": true, "supersededBy": true, "language": true
  },
  "additionalProperties": false
}
